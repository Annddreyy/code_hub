{
    "name": "cover",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "lint": "npm run lint:eslint && npm run lint:prettier",
        "lint:eslint": "eslint .",
        "lint:prettier": "prettier . --check",
        "lintfix": "eslint . --fix && prettier --write --list-different .",
        "typecheck": "npx nuxt typecheck",
        "prepare": "cd ../.. && husky frontend/cover/.husky"
    },
    "dependencies": {
        "@nuxt/eslint": "^1.15.2",
        "axios": "^1.15.2",
        "nuxt": "^4.4.2",
        "sass-embedded": "^1.99.0",
        "vue": "^3.5.30",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@eslint/css": "^0.14.1",
        "@eslint/js": "^9.39.4",
        "@eslint/json": "^0.14.0",
        "@eslint/markdown": "^7.5.1",
        "eslint": "^10.1.0",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "prettier": "3.8.1",
        "typescript-eslint": "^8.58.0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,vue}": [
            "npx eslint --fix",
            "npx prettier --write"
        ],
        "*.{json,css,scss,md}": [
            "npx prettier --write"
        ]
    }
}
