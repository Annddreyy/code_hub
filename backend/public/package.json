{
    "name": "public-service",
    "version": "1.0.0",
    "description": "Public microservice",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
        "build": "tsc && tsc-alias",
        "start": "node -r tsconfig-paths/register dist/index.js",
        "migrate": "ts-node -r tsconfig-paths/register src/migrations/index.ts"
    },
    "dependencies": {
        "@types/dotenv": "^6.1.1",
        "@types/jsonwebtoken": "^9.0.10",
        "camelcase-keys": "^10.0.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "cors": "^2.8.5",
        "date-fns": "^3.6.0",
        "dotenv": "^17.4.2",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.3",
        "ms": "^2.1.3",
        "pg": "^8.12.0",
        "reflect-metadata": "^0.2.2",
        "swagger-ui-express": "^5.0.0",
        "uuid": "^10.0.0",
        "winston": "^3.13.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/pg": "^8.11.6",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/uuid": "^10.0.0",
        "prettier": "^3.8.3",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.4.5"
    }
}
